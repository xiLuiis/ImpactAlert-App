<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FAFAFA"
    android:padding="16dp">

    <!-- Tabs Navigation -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="8dp">

        <Button
            android:id="@+id/btnTabHome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Home"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnTabSettings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Settings"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnTabBle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Debug"
            android:textSize="12sp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- HOME PAGE -->
    <ScrollView
        android:id="@+id/homeScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/txtMcuStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MCU Status: Checking..."
                android:textSize="18sp"
                android:textColor="#000000" />

            <Button
                android:id="@+id/btnMain"
                android:layout_width="240dp"
                android:layout_height="240dp"
                android:layout_marginTop="20dp"
                android:backgroundTint="#2ECC71"
                android:text="SYSTEM NORMAL"
                android:textColor="#FFFFFF"
                android:textSize="26sp" />

            <TextView
                android:id="@+id/txtCountdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text=""
                android:textColor="#D93D33"
                android:textSize="24sp"
                android:textStyle="bold" />

            <!-- MENSAJE DE ESTADO GENÉRICO (Debajo del botón principal) -->
            <TextView
                android:id="@+id/txtMechanismStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="Sistema de monitoreo activo"
                android:textSize="14sp"
                android:textColor="#7F8C8D" />

            <Button
                android:id="@+id/btnConnectBle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Scan Devices" />

            <Button
                android:id="@+id/btnEmergencyContacts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Emergency Contacts" />

            <Button
                android:id="@+id/btnEmergency"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:backgroundTint="#FF3B30"
                android:text="CALL 911"
                android:textColor="#FFFFFF" />

            <CheckBox
                android:id="@+id/chkDebugMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:layout_marginBottom="20dp"
                android:text="ENABLE DEBUG MODE"
                android:textSize="12sp"
                android:textColor="#000000" />
        </LinearLayout>
    </ScrollView>

    <!-- SETTINGS PAGE -->
    <ScrollView
        android:id="@+id/settingsScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Preferences"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#000000" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchSmsEnabled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Auto Send Emergency SMS"
                android:textSize="18sp"
                android:textColor="#000000"
                android:padding="10dp"
                android:checked="true" />

            <!-- NUEVA OPCIÓN: INCLUIR UBICACIÓN GPS -->
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchIncludeLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Include GPS Location"
                android:textSize="18sp"
                android:textColor="#000000"
                android:padding="10dp"
                android:checked="true" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="If enabled, an SMS will be sent to your contacts after the countdown."
                android:textSize="14sp"
                android:textColor="#333333"
                android:paddingLeft="10dp" />

            <!-- PERFILES DE SENSIBILIDAD -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Crash Sensitivity Profile"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:layout_marginTop="32dp"
                android:paddingLeft="10dp" />

            <RadioGroup
                android:id="@+id/radioGroupSensitivity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:padding="10dp">

                <RadioButton
                    android:id="@+id/radioHigh"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="High (Sensible)"
                    android:textColor="#000000" />

                <RadioButton
                    android:id="@+id/radioMedium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Medium (Medio)"
                    android:textColor="#000000"
                    android:checked="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="(Recomendado)"
                    android:textSize="10sp"
                    android:textColor="#2ECC71"
                    android:paddingLeft="32dp"
                    android:layout_marginTop="-8dp" />

                <RadioButton
                    android:id="@+id/radioLow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Low (Nada sensible)"
                    android:textColor="#000000" />
            </RadioGroup>

        </LinearLayout>
    </ScrollView>

    <!-- DEBUG PAGE -->
    <ScrollView
        android:id="@+id/bleScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Debug Data"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#000000" />

            <Button
                android:id="@+id/btnTestAlert"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="TEST ALERT"
                android:backgroundTint="#FF9800"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/txtSmsLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="SMS Log: -"
                android:background="#EEEEEE"
                android:padding="10dp"
                android:textColor="#1B5E20"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/txtBleStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="BLE Status: -"
                android:textColor="#000000" />

            <TextView
                android:id="@+id/txtAcc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="ACC: -"
                android:textColor="#000000" />

            <TextView
                android:id="@+id/txtGyro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="GYRO: -"
                android:textColor="#000000" />

            <TextView
                android:id="@+id/txtAccMag"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="ACC MAG: -"
                android:textColor="#000000" />

            <TextView
                android:id="@+id/txtGyroMag"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="GYRO MAG: -"
                android:textColor="#000000" />

            <TextView
                android:id="@+id/txtCrashState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="State: NORMAL"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#000000" />
        </LinearLayout>
    </ScrollView>

</LinearLayout>